{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/spec-gate.py",
            "timeout": 10,
            "statusMessage": "DocDD: 仕様ゲートを確認中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/post-tool-notify.py",
            "timeout": 10,
            "statusMessage": "DocDD: ドキュメント整合性を確認中..."
          }
        ]
      }
    ]
  }
}
