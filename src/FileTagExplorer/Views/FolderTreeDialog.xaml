<Window x:Class="FileTagExplorer.Views.FolderTreeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileTagExplorer.ViewModels"
        Title="移動先フォルダを選択" Height="450" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" FontWeight="Bold">
            移動先フォルダを選択してください:
        </TextBlock>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button IsDefault="True" Click="OkButton_Click"
                    Background="#2196F3" Foreground="White" Width="80">
                OK
            </Button>
            <Button IsCancel="True" Click="CancelButton_Click" Width="80">
                キャンセル
            </Button>
        </StackPanel>

        <!-- フォルダツリー -->
        <Border BorderBrush="#CCC" BorderThickness="1">
            <TreeView x:Name="FolderTree" ItemsSource="{Binding}"
                      SelectedItemChanged="FolderTree_SelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FolderNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁 " FontSize="13"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </DockPanel>
</Window>
